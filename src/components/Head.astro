---
// Override of Starlight's Head: default head + JSON-LD structured data so
// search engines and LLM crawlers get typed metadata on every page. The graph
// (article + breadcrumb + section-specific nodes) is built in structured-data.mjs.
import Default from '@astrojs/starlight/components/Head.astro';
import { getCollection } from 'astro:content';
import { SITE } from '../../site.config.mjs';
import { buildGraph } from '../lib/structured-data.mjs';

const route = Astro.locals?.starlightRoute;
const entry = route?.entry;
const url = new URL(Astro.url.pathname, SITE.url).href;

let jsonLd = null;
if (entry) {
  // route.entry may not carry the raw markdown body; read it from the docs
  // collection so the HowTo / glossary parsers have real content to work with.
  let body = typeof entry.body === 'string' ? entry.body : '';
  if (!body) {
    const docs = await getCollection('docs');
    body = docs.find((d) => d.id === entry.id)?.body ?? '';
  }
  jsonLd = buildGraph({ entry, body, url, SITE });
}
---

<Default />
{jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}
{/* Shared consent + analytics loader, served from the apex (80x.ai). /docs is
    reverse-proxied under 80x.ai, so this is same-origin and shares one consent
    choice with the rest of the site. No-op on the standalone preview domain. */}
<script is:inline defer src="/consent-analytics.js"></script>
<script is:inline>
  // Unify the theme across the whole 80x.ai property. Runs after Starlight's
  // own provider (rendered by <Default/> above), so this is the last word
  // before first paint. Precedence: ?theme= param (screenshot verification) →
  // the SHARED `bc-theme` key that the landing site writes → dark (the
  // property-wide default). Reading `bc-theme` here is what makes a theme
  // chosen on 80x.ai carry into the docs; the toggle writes it back.
  (() => {
    var params = new URLSearchParams(window.location.search);
    var override = params.get('theme');
    var stored = null;
    try {
      stored =
        localStorage.getItem('bc-theme') || localStorage.getItem('starlight-theme');
    } catch (e) {}
    var theme =
      override === 'light' || override === 'dark'
        ? override
        : stored === 'light' || stored === 'dark'
          ? stored
          : 'dark';
    var apply = function () {
      document.documentElement.setAttribute('data-theme', theme);
    };
    apply(); // before first paint
    document.addEventListener('DOMContentLoaded', apply, { once: true });
  })();
</script>
<script is:inline>
  // Copy buttons on branded diagrams (src/components/... -> remark-diagrams.mjs).
  // Delegated so it covers every .diagram figure on the page with one listener.
  document.addEventListener('click', function (e) {
    var btn = e.target.closest && e.target.closest('[data-diagram-copy]');
    if (!btn) return;
    var src = btn.getAttribute('data-src') || '';
    var restore = function (label) {
      var prev = btn.textContent;
      btn.textContent = label;
      setTimeout(function () {
        btn.textContent = prev === label ? 'Copy' : prev;
      }, 1500);
    };
    if (navigator.clipboard && navigator.clipboard.writeText) {
      navigator.clipboard.writeText(src).then(
        function () { restore('Copied ✓'); },
        function () { restore('Copy failed'); }
      );
    } else {
      restore('Copy failed');
    }
  });
</script>
