---
// Override of Starlight's SocialIcons slot. Renders the product-header CTA
// pair: a bordered "Contact" pill and the primary "Book a teardown" pill, so
// the two properties share one header. The teardown is the primary conversion
// across 80x, so it carries the brand lime accent (echoing the wordmark badge)
// and stays visible on every page, giving a reader who lands on a deep docs
// page a direct path to book. The default social icons (GitHub) are
// intentionally NOT rendered here: the landing header carries none either, and
// the repo stays reachable via each page's "Edit" link and the footer. Sits in
// the header right-group, before the theme toggle.
import { SITE } from '../../site.config.mjs';
---

<a class="header-contact" href={SITE.contact}>Contact</a>
<a class="header-cta" href={SITE.bookTeardown}>{SITE.bookTeardownLabel}</a>
