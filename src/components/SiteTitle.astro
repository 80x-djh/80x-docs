---
// Override of Starlight's SiteTitle. Two jobs: (1) make the wordmark a
// breadcrumb — "80x" links back to the studio home, "/ Docs" to the docs home —
// so the docs read as one property with 80x.ai; (2) carry the studio's primary
// nav (Services / Work / Tools) on the left, mirroring the landing header so a
// reader can jump back into the studio from any doc. The nav hides below md;
// the wordmark stays as the always-visible escape hatch to 80x.ai.
import { SITE } from '../../site.config.mjs';
---

<div class="site-title sl-flex" translate="no">
  <a href={SITE.studioUrl} class="wordmark-brand" aria-label="80x — home">
    {/* The canonical 80x mark: real Geist Mono Bold "80x", ink on brand lime.
        Self-contained (outlined paths + baked colors), so it needs no font and
        reads on both the light and dark docs headers. */}
    <svg class="wordmark-logo" viewBox="0 0 1024 1024" width="27" height="27" role="img" aria-label="80x">
      <rect width="1024" height="1024" rx="164" ry="164" fill="#E4F222"></rect>
      <g transform="matrix(0.438519,0,0,-0.438519,116.4563,667.6741)" fill="#0B0B09">
        <g transform="translate(0,0)"><path d="M300 -16Q182 -16 110.0 37.5Q38 91 38 194Q38 263 76.0 311.5Q114 360 179 381Q129 400 98.0 437.5Q67 475 67 530Q67 587 96.0 631.5Q125 676 177.5 701.0Q230 726 300 726Q370 726 422.5 701.0Q475 676 504.0 631.5Q533 587 533 530Q533 475 502.0 437.5Q471 400 420 381Q486 360 524.0 312.0Q562 264 562 194Q562 91 490.0 37.5Q418 -16 300 -16ZM300 438Q339 438 362.5 458.5Q386 479 386 521Q386 558 362.5 579.0Q339 600 300 600Q261 600 237.5 579.0Q214 558 214 521Q214 479 237.5 458.5Q261 438 300 438ZM300 110Q348 110 382.0 132.5Q416 155 416 208Q416 259 385.5 288.0Q355 317 300 317Q245 317 214.5 288.0Q184 259 184 208Q184 155 218.0 132.5Q252 110 300 110Z"></path></g>
        <g transform="translate(600,0)"><path d="M300 -16Q220 -16 162.5 29.0Q105 74 74.5 157.0Q44 240 44 354Q44 469 74.5 552.5Q105 636 162.5 681.0Q220 726 300 726Q380 726 437.5 681.0Q495 636 525.5 552.5Q556 469 556 354Q556 240 525.5 157.0Q495 74 437.5 29.0Q380 -16 300 -16ZM190 354Q190 291 199 243L368 562Q341 600 300 600Q248 600 219.0 538.5Q190 477 190 354ZM300 110Q352 110 381.0 171.0Q410 232 410 354Q410 418 401 467L232 148Q259 110 300 110Z"></path></g>
        <g transform="translate(1200,0)"><path d="M34 0 224 274 42 536H190L300 367L409 536H557L378 274L566 0H419L300 183L182 0Z"></path></g>
      </g>
    </svg>
  </a>
  <span class="wordmark-sep" aria-hidden="true">/</span>
  <a href="/docs" class="wordmark-section">Docs</a>
</div>
<nav class="studio-nav" aria-label="80x">
  {SITE.studioNav.map((item) => <a href={item.href}>{item.label}</a>)}
</nav>
