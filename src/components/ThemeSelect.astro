---
// Override of Starlight's ThemeSelect (the "Auto" dropdown) with a two-state
// icon toggle that matches the 80x.ai studio toggle exactly (a quiet bordered
// icon button, sun in dark / moon in light). It writes the SHARED property key
// `bc-theme`, the same key the landing site uses, so a theme choice made
// anywhere on 80x.ai carries across to the docs and back. It also mirrors into
// Starlight's own `starlight-theme` key so Starlight's state stays coherent.
// The no-FOUC application on load lives in Head.astro.
---

<button
  id="x-theme-toggle"
  type="button"
  class="x-theme-toggle"
  aria-label="Toggle light and dark theme"
  title="Toggle light and dark theme"
>
  <svg class="ico ico-sun" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <circle cx="12" cy="12" r="4"></circle>
    <path d="M12 2v2"></path><path d="M12 20v2"></path>
    <path d="m4.93 4.93 1.41 1.41"></path><path d="m17.66 17.66 1.41 1.41"></path>
    <path d="M2 12h2"></path><path d="M20 12h2"></path>
    <path d="m6.34 17.66-1.41 1.41"></path><path d="m19.07 4.93-1.41 1.41"></path>
  </svg>
  <svg class="ico ico-moon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M12 3a6.364 6.364 0 0 0 9 9 9 9 0 1 1-9-9Z"></path>
  </svg>
</button>

<script is:inline>
  (function () {
    var btn = document.getElementById('x-theme-toggle');
    if (!btn) return;
    var current = function () {
      return document.documentElement.getAttribute('data-theme') === 'light'
        ? 'light'
        : 'dark';
    };
    btn.addEventListener('click', function () {
      var next = current() === 'dark' ? 'light' : 'dark';
      document.documentElement.setAttribute('data-theme', next);
      try {
        // The shared, property-wide key (same one 80x.ai uses) …
        localStorage.setItem('bc-theme', next);
        // … and Starlight's own key, so its internal state agrees.
        localStorage.setItem('starlight-theme', next);
      } catch (e) {}
      if (window.StarlightThemeProvider && window.StarlightThemeProvider.updatePickers) {
        try { window.StarlightThemeProvider.updatePickers(next); } catch (e) {}
      }
    });
  })();
</script>
