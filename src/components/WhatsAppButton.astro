---
// Floating "chat with the founder" WhatsApp button, rendered on every docs page
// via the Footer override. Matches the 80x.ai studio button: Daniel's headshot
// (served same-origin from the apex root) with a small WhatsApp badge, avatar-
// only on mobile, avatar + label from `sm` up. Plain link, no JS; the shared
// consent-gated analytics loader captures the click via [data-track].
import { SITE } from '../../site.config.mjs';
---

<a
  class="wa-fab not-content"
  href={SITE.whatsapp}
  target="_blank"
  rel="noopener noreferrer"
  data-track="whatsapp_message_clicked"
  aria-label="Chat with Daniel, founder of 80x, on WhatsApp"
  title="Chat with the founder on WhatsApp"
>
  <span class="wa-avatar">
    <img src="https://80x.ai/daniel-hull.jpg" alt="" width="44" height="44" loading="lazy" decoding="async" />
    <span class="wa-badge">
      <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
      </svg>
    </span>
  </span>
  <span class="wa-label">Chat with the founder</span>
</a>

<style>
  .wa-fab {
    position: fixed;
    right: 1.25rem;
    bottom: 1.25rem;
    z-index: 90;
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.375rem;
    border: 1px solid var(--sl-color-hairline);
    border-radius: 999px;
    background: var(--sl-color-bg);
    color: var(--sl-color-white);
    font-size: 13.5px;
    font-weight: 500;
    line-height: 1;
    text-decoration: none;
    box-shadow: 0 6px 24px rgba(0, 0, 0, 0.22);
    transition: border-color 120ms ease;
  }
  .wa-fab:hover {
    border-color: var(--sl-color-white);
  }
  @media (min-width: 640px) {
    .wa-fab {
      right: 1.5rem;
      bottom: 1.5rem;
      padding-right: 1rem;
    }
  }
  .wa-avatar {
    position: relative;
    display: inline-block;
    flex: none;
  }
  .wa-avatar img {
    display: block;
    width: 44px;
    height: 44px;
    border-radius: 999px;
    object-fit: cover;
  }
  .wa-badge {
    position: absolute;
    right: -2px;
    bottom: -2px;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 20px;
    height: 20px;
    border-radius: 999px;
    background: var(--sl-color-bg);
  }
  .wa-badge svg {
    width: 15px;
    height: 15px;
    color: #25d366;
  }
  .wa-label {
    display: none;
    padding-right: 2px;
  }
  @media (min-width: 640px) {
    .wa-label {
      display: inline;
    }
  }
</style>
